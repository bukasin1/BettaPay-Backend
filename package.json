{
  "name": "bettapay-backend",
  "version": "0.1.0",
  "private": true,
  "description": "BettaPay backend services — API gateway, FX engine, settlement engine, indexer",
  "type": "module",
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "workspaces": [
    "services/*",
    "shared/*"
  ],
  "scripts": {
    "dev": "pnpm --parallel --filter './services/*' dev",
    "build": "pnpm --filter './shared/*' build && pnpm --filter './services/*' build",
    "type-check": "pnpm -r type-check",
    "lint": "pnpm -r lint",
    "gateway:dev": "pnpm --filter api-gateway dev",
    "fx:dev": "pnpm --filter fx-engine dev",
    "settlement:dev": "pnpm --filter settlement-engine dev",
    "indexer:dev": "pnpm --filter indexer dev",
    "clean": "pnpm -r clean && rm -rf node_modules"
  },
  "devDependencies": {
    "prettier": "^3.1.1",
    "typescript": "^5.3.3"
  }
}
